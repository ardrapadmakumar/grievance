@model List<grievance.Models.Grievance>
@using grievance.Models
@{
    Layout = "_Layout"; ViewData["Title"] = "Department Grievances";
}

<div class="pg-header">
    <h1 class="pg-title">Department Grievances</h1>
    <p class="pg-sub">Review and update grievances from your department students</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">✓ @TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error">✕ @TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="card">
        <div class="empty"><div class="empty-ico">✉</div><div>No grievances in your department.</div></div>
    </div>
}
else
{
    <div class="card">
        <div class="tbl-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Submitted</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in Model)
                    {
                        <tr>
                            <td>
                                <div style="font-weight:600">@g.Student.Name</div>
                                <div class="text-muted text-sm">@g.Student.RollNumber</div>
                            </td>
                            <td>
                                <div>@g.Title</div>
                                <div class="text-muted text-sm" style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                    @g.Description
                                </div>
                            </td>
                            <td class="text-muted text-sm">@g.Category</td>
                            <td class="text-muted text-sm">@g.SubmittedAt.ToString("dd MMM yyyy")</td>
                            <td><span class="badge b-@g.Status.ToString().ToLower()">@g.Status</span></td>
                            <td>
                                @if (g.Status != GrievanceStatus.Solved && g.Status != GrievanceStatus.Resolved && g.Status != GrievanceStatus.Rejected)
                                {
                                    <button class="btn btn-warn btn-sm"
                                            onclick="openUpdate(@g.Id, '@g.Title.Replace("'", "\\'")')">
                                        Update
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted text-sm">Closed</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Update Modal -->
<div class="modal-bg" id="updateModal">
    <div class="modal">
        <div class="flex items-center justify-between mb-4">
            <div class="modal-title">Update Grievance</div>
            <span class="modal-close" onclick="closeUpdate()">✕</span>
        </div>
        <p class="text-sm text-muted mb-4">Grievance: <strong id="gTitle" style="color:var(--text)"></strong></p>

        <form method="post" action="/Teacher/UpdateGrievance">
            <input type="hidden" name="id" id="gId" />
            <div class="form-group">
                <label>Update Status</label>
                <select name="status">
                    <option value="InProgress">In Progress</option>
                    <option value="Solved">Solved</option>
                    <option value="Forwarded">Forward to Principal</option>
                </select>
            </div>
            <div class="form-group">
                <label>Remarks</label>
                <textarea name="remarks" placeholder="Add remarks for the student..."></textarea>
            </div>
            <div class="flex gap-2">
                <button type="submit" class="btn btn-primary">Update</button>
                <button type="button" class="btn btn-ghost" onclick="closeUpdate()">Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openUpdate(id, title) {
            document.getElementById('gId').value = id;
            document.getElementById('gTitle').textContent = title;
            document.getElementById('updateModal').classList.add('show');
        }
        function closeUpdate() {
            document.getElementById('updateModal').classList.remove('show');
        }
    </script>
}
