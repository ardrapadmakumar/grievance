@model grievance.Models.LoginViewModel
@{ Layout = "_Layout"; ViewData["Title"] = "Login"; }

<style>
    .auth-wrap { min-height:100vh; display:flex; align-items:center; justify-content:center; background:var(--bg); }
    .auth-box  { width:420px; }
    .auth-logo { font-family:'Syne',sans-serif; font-size:22px; font-weight:800; margin-bottom:28px; }
    .auth-logo span { color:var(--accent); }
    .auth-title{ font-size:24px; font-weight:800; margin-bottom:6px; }
    .auth-sub  { color:var(--muted); font-size:14px; margin-bottom:28px; }
    .auth-card { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:30px; }
    .demo-box  { background:var(--surface2); border:1px solid var(--border); border-radius:10px; padding:14px 16px; margin-top:20px; }
    .demo-title{ font-size:11px; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:10px; font-weight:600; }
    .demo-row  { display:flex; justify-content:space-between; align-items:center; margin-bottom:6px; }
    .demo-row:last-child { margin-bottom:0; }
    .demo-label{ font-size:12px; color:var(--muted); }
    .demo-cred { font-size:12px; font-family:monospace; color:var(--text); }
    .demo-btn  { font-size:11px; padding:3px 9px; border-radius:5px; background:var(--border); border:none; color:var(--muted); cursor:pointer; font-family:'DM Sans',sans-serif; transition:all .15s; }
    .demo-btn:hover { color:var(--accent); }
</style>

<div class="auth-wrap">
  <div class="auth-box">
    <div class="auth-logo"><span>G</span>MS Portal</div>
    <h1 class="auth-title">Welcome back</h1>
    <p class="auth-sub">Sign in to your account to continue</p>

    <div class="auth-card">
      @if (ViewBag.Error != null)
      {
        <div class="alert alert-error">@ViewBag.Error</div>
      }
      @if (TempData["Success"] != null)
      {
        <div class="alert alert-success">@TempData["Success"]</div>
      }

      <form method="post">
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" name="Email" value="@Model?.Email" placeholder="you@college.edu" required />
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="Password" placeholder="••••••••" required />
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:4px;">
          Sign In →
        </button>
      </form>

      <hr class="div" />
      <p class="text-sm text-muted" style="text-align:center">
        New student? <a href="/Account/Register" style="color:var(--accent)">Create account</a>
      </p>
    </div>

    <!-- Demo credentials quick-fill -->
    <div class="demo-box">
      <div class="demo-title">Demo Credentials</div>
      <div class="demo-row">
        <span class="demo-label">🎓 Student</span>
        <span class="demo-cred">arjun@student.edu</span>
        <button class="demo-btn" onclick="fill('arjun@student.edu','student123')">Use</button>
      </div>
      <div class="demo-row">
        <span class="demo-label">📚 Teacher</span>
        <span class="demo-cred">ravi@college.edu</span>
        <button class="demo-btn" onclick="fill('ravi@college.edu','teacher123')">Use</button>
      </div>
      <div class="demo-row">
        <span class="demo-label">🏫 Principal</span>
        <span class="demo-cred">principal@college.edu</span>
        <button class="demo-btn" onclick="fill('principal@college.edu','principal123')">Use</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
function fill(email, pass) {
    document.querySelector('input[name="Email"]').value = email;
    document.querySelector('input[name="Password"]').value = pass;
}
</script>
}
