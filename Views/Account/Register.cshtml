@model grievance.Models.RegisterViewModel
@{ Layout = "_Layout"; ViewData["Title"] = "Register"; }

<style>
    .auth-wrap { min-height:100vh; display:flex; align-items:center; justify-content:center; background:var(--bg); padding:30px 0; }
    .auth-box  { width:460px; }
    .auth-logo { font-family:'Syne',sans-serif; font-size:22px; font-weight:800; margin-bottom:28px; }
    .auth-logo span { color:var(--accent); }
    .auth-title{ font-size:24px; font-weight:800; margin-bottom:6px; }
    .auth-sub  { color:var(--muted); font-size:14px; margin-bottom:28px; }
    .auth-card { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:30px; }
</style>

<div class="auth-wrap">
  <div class="auth-box">
    <div class="auth-logo"><span>G</span>MS Portal</div>
    <h1 class="auth-title">Create Account</h1>
    <p class="auth-sub">Student registration — teachers are added by admin</p>

    <div class="auth-card">
      @if (ViewBag.Error != null)
      {
        <div class="alert alert-error">@ViewBag.Error</div>
      }

      <form method="post">
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="Name" value="@Model?.Name" placeholder="e.g. Arjun Dev" required />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Department</label>
            <select name="Department">
              @foreach (var d in Enum.GetValues<grievance.Models.Department>())
              {
                <option value="@d">@d</option>
              }
            </select>
          </div>
          <div class="form-group">
            <label>Roll Number</label>
            <input type="text" name="RollNumber" value="@Model?.RollNumber" placeholder="e.g. CSE001" required />
          </div>
        </div>
        <div class="form-group">
          <label>College Email</label>
          <input type="email" name="Email" value="@Model?.Email" placeholder="you@student.edu" required />
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="Password" placeholder="Min. 6 characters" required minlength="6" />
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:4px;">
          Create Account →
        </button>
      </form>

      <hr class="div" />
      <p class="text-sm text-muted" style="text-align:center">
        Already have an account? <a href="/Account/Login" style="color:var(--accent)">Sign in</a>
      </p>
    </div>
  </div>
</div>
