@model grievance.Models.GrievanceFormViewModel
@using grievance.Models
@{
    Layout = "_Layout"; ViewData["Title"] = "Submit Grievance";
}

<div class="pg-header">
    <h1 class="pg-title">Submit a Grievance</h1>
    <p class="pg-sub">Your grievance will be sent to your department teacher panel</p>
</div>

<div style="max-width:620px">
    <div class="card">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-error">@ViewBag.Error</div>
        }

        <form method="post">
            <div class="form-group">
                <label>Grievance Title</label>
                <input type="text" name="Title" value="@Model?.Title"
                       placeholder="e.g. Lab equipment not working" required />
            </div>

            <div class="form-group">
                <label>Category</label>
                <select name="Category">
                    @foreach (var c in Enum.GetValues<GrievanceCategory>())
                    {
                        <option value="@c">@c</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea name="Description" placeholder="Describe your grievance in detail..." required>@Model?.Description</textarea>
            </div>

            <div class="flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Submit Grievance →</button>
                <a href="/Student/Index" class="btn btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>
