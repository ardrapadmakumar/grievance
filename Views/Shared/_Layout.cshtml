<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – GMS Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg:        #0f1117;
            --surface:   #1a1d27;
            --surface2:  #22263a;
            --border:    #2e3350;
            --accent:    #6c63ff;
            --green:     #26de81;
            --yellow:    #f7b731;
            --red:       #fc5c65;
            --text:      #e8eaf0;
            --muted:     #7f8aab;
        }
        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
        body { background:var(--bg); color:var(--text); font-family:'DM Sans',sans-serif; min-height:100vh; }
        h1,h2,h3,h4,h5 { font-family:'Syne',sans-serif; }
        a { text-decoration:none; color:inherit; }

        /* ── Layout ── */
        .app-layout { display:flex; min-height:100vh; }

        /* ── Sidebar ── */
        .sidebar {
            width:250px; background:var(--surface); border-right:1px solid var(--border);
            display:flex; flex-direction:column; position:fixed; top:0; left:0; height:100vh; z-index:50;
        }
        .sb-logo {
            padding:24px 22px 18px; font-family:'Syne',sans-serif; font-size:18px;
            font-weight:800; border-bottom:1px solid var(--border); letter-spacing:-0.5px;
        }
        .sb-logo span { color:var(--accent); }
        .sb-user { padding:18px 22px; border-bottom:1px solid var(--border); }
        .role-pill {
            display:inline-block; font-size:10px; font-weight:700; letter-spacing:1.5px;
            text-transform:uppercase; padding:3px 10px; border-radius:20px; margin-bottom:7px;
        }
        .pill-student   { background:rgba(38,222,129,.15); color:var(--green); }
        .pill-teacher   { background:rgba(108,99,255,.15);  color:var(--accent); }
        .pill-principal { background:rgba(247,183,49,.15);  color:var(--yellow); }
        .sb-name { font-family:'Syne',sans-serif; font-size:14px; font-weight:700; }
        .sb-dept { font-size:12px; color:var(--muted); margin-top:2px; }

        .sb-nav { flex:1; padding:12px 0; overflow-y:auto; }
        .sb-section { font-size:10px; text-transform:uppercase; letter-spacing:2px; color:var(--muted); padding:10px 22px 4px; margin-top:6px; }
        .sb-link {
            display:flex; align-items:center; gap:11px; padding:10px 22px;
            color:var(--muted); font-size:13.5px; font-weight:500;
            border-left:3px solid transparent; transition:all .18s;
        }
        .sb-link:hover { color:var(--text); background:var(--surface2); }
        .sb-link.active { color:var(--accent); background:rgba(108,99,255,.08); border-left-color:var(--accent); }
        .sb-link .ico { font-size:16px; width:18px; text-align:center; }

        .sb-foot { padding:14px 22px; border-top:1px solid var(--border); }
        .sb-logout { display:flex; align-items:center; gap:9px; color:var(--muted); font-size:13px; transition:color .18s; }
        .sb-logout:hover { color:var(--red); }

        /* ── Main ── */
        .main-content { margin-left:250px; flex:1; padding:32px 36px; }

        /* ── Page header ── */
        .pg-header { margin-bottom:26px; }
        .pg-title  { font-size:26px; font-weight:800; letter-spacing:-.5px; }
        .pg-sub    { color:var(--muted); font-size:13.5px; margin-top:3px; }

        /* ── Stats ── */
        .stats-row { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:14px; margin-bottom:26px; }
        .stat-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:18px 22px; }
        .stat-lbl  { font-size:11px; text-transform:uppercase; letter-spacing:1px; color:var(--muted); }
        .stat-val  { font-family:'Syne',sans-serif; font-size:30px; font-weight:800; margin-top:3px; }
        .c-green  { color:var(--green); }
        .c-yellow { color:var(--yellow); }
        .c-purple { color:var(--accent); }
        .c-red    { color:var(--red); }
        .c-muted  { color:var(--muted); }

        /* ── Card ── */
        .card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:22px; margin-bottom:22px; }
        .card-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:18px; }
        .card-title { font-family:'Syne',sans-serif; font-size:15px; font-weight:700; }

        /* ── Table ── */
        .tbl-wrap { overflow-x:auto; }
        table  { width:100%; border-collapse:collapse; font-size:13.5px; }
        th { text-align:left; padding:9px 14px; font-size:10.5px; text-transform:uppercase; letter-spacing:1px; color:var(--muted); border-bottom:1px solid var(--border); font-weight:600; }
        td { padding:12px 14px; border-bottom:1px solid rgba(46,51,80,.45); vertical-align:middle; }
        tr:last-child td { border-bottom:none; }
        tr:hover td { background:var(--surface2); }

        /* ── Badges ── */
        .badge { display:inline-block; font-size:11px; font-weight:600; padding:3px 10px; border-radius:20px; }
        .b-pending      { background:rgba(247,183,49,.15);  color:var(--yellow); }
        .b-inprogress   { background:rgba(108,99,255,.15);  color:var(--accent); }
        .b-solved, .b-resolved { background:rgba(38,222,129,.15); color:var(--green); }
        .b-forwarded    { background:rgba(252,92,101,.15);  color:var(--red); }
        .b-rejected     { background:rgba(252,92,101,.15);  color:var(--red); }
        .b-underreview  { background:rgba(247,183,49,.15);  color:var(--yellow); }
        .b-requested       { background:rgba(247,183,49,.15);  color:var(--yellow); }
        .b-ongoingevaluation { background:rgba(108,99,255,.15); color:var(--accent); }
        .b-nochange        { background:rgba(127,138,171,.2);  color:var(--muted); }
        .b-gradechanged    { background:rgba(38,222,129,.15);  color:var(--green); }

        /* ── Buttons ── */
        .btn { display:inline-flex; align-items:center; gap:6px; padding:8px 16px; border-radius:8px; font-size:13px; font-weight:600; border:none; cursor:pointer; font-family:'DM Sans',sans-serif; transition:all .18s; }
        .btn-primary { background:var(--accent); color:#fff; }
        .btn-primary:hover { background:#5a52e0; }
        .btn-success { background:rgba(38,222,129,.12); color:var(--green); border:1px solid rgba(38,222,129,.3); }
        .btn-success:hover { background:rgba(38,222,129,.22); }
        .btn-danger  { background:rgba(252,92,101,.12); color:var(--red);   border:1px solid rgba(252,92,101,.3); }
        .btn-danger:hover  { background:rgba(252,92,101,.22); }
        .btn-warn    { background:rgba(247,183,49,.12);  color:var(--yellow);border:1px solid rgba(247,183,49,.3); }
        .btn-warn:hover    { background:rgba(247,183,49,.22); }
        .btn-ghost   { background:var(--surface2); color:var(--text); }
        .btn-ghost:hover   { background:var(--border); }
        .btn-sm { padding:5px 11px; font-size:12px; }

        /* ── Forms ── */
        .form-group { margin-bottom:16px; }
        label { display:block; font-size:11.5px; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:5px; }
        input[type=text],input[type=email],input[type=password],input[type=number],select,textarea {
            width:100%; background:var(--bg); border:1px solid var(--border); color:var(--text);
            padding:9px 13px; border-radius:8px; font-size:13.5px; font-family:'DM Sans',sans-serif;
            transition:border-color .18s; outline:none;
        }
        input:focus,select:focus,textarea:focus { border-color:var(--accent); }
        textarea { resize:vertical; min-height:90px; }
        select option { background:var(--surface); }
        .form-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }

        /* ── Alerts ── */
        .alert { padding:11px 15px; border-radius:8px; font-size:13.5px; margin-bottom:18px; }
        .alert-success { background:rgba(38,222,129,.1);  border:1px solid rgba(38,222,129,.3); color:var(--green); }
        .alert-error   { background:rgba(252,92,101,.1);  border:1px solid rgba(252,92,101,.3); color:var(--red); }

        /* ── Modal ── */
        .modal-bg { display:none; position:fixed; inset:0; background:rgba(0,0,0,.65); z-index:200; align-items:center; justify-content:center; }
        .modal-bg.show { display:flex; }
        .modal { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:26px; width:460px; max-width:95vw; max-height:88vh; overflow-y:auto; }
        .modal-title { font-family:'Syne',sans-serif; font-size:17px; font-weight:700; margin-bottom:18px; }
        .modal-close { cursor:pointer; color:var(--muted); font-size:20px; line-height:1; }
        .modal-close:hover { color:var(--red); }

        /* ── Empty state ── */
        .empty { text-align:center; padding:50px 20px; color:var(--muted); }
        .empty-ico { font-size:44px; margin-bottom:10px; }

        /* ── Misc ── */
        .flex          { display:flex; }
        .flex-wrap     { flex-wrap:wrap; }
        .items-center  { align-items:center; }
        .justify-between { justify-content:space-between; }
        .gap-2 { gap:8px; }
        .gap-3 { gap:12px; }
        .mt-3  { margin-top:12px; }
        .mt-4  { margin-top:16px; }
        .mb-4  { margin-bottom:16px; }
        .text-sm   { font-size:13px; }
        .text-muted{ color:var(--muted); }
        .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
        hr.div  { border:none; border-top:1px solid var(--border); margin:18px 0; }
    </style>
</head>
<body>
@{
    var role     = Context.Session.GetString("UserRole") ?? "";
    var userName = Context.Session.GetString("UserName") ?? "";
    var userDept = Context.Session.GetString("UserDept") ?? "";
    var loggedIn = !string.IsNullOrEmpty(role);
    var action   = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

@if (loggedIn)
{
<div class="app-layout">
  <aside class="sidebar">
    <div class="sb-logo"><span>G</span>MS <span style="color:var(--muted);font-size:12px;font-weight:400">Portal</span></div>
    <div class="sb-user">
      <div class="role-pill pill-@role.ToLower()">@role</div>
      <div class="sb-name">@userName</div>
      @if (role != "Principal") { <div class="sb-dept">@userDept</div> }
    </div>
    <nav class="sb-nav">
      @if (role == "Student")
      {
        <div class="sb-section">Student</div>
        <a class="sb-link @(action=="Index"?"active":"")"           href="/Student/Index">          <span class="ico">⊞</span> Dashboard       </a>
        <a class="sb-link @(action=="SubmitGrievance"?"active":"")" href="/Student/SubmitGrievance"><span class="ico">✉</span> Submit Grievance </a>
        <a class="sb-link @(action=="Marks"?"active":"")"           href="/Student/Marks">          <span class="ico">◈</span> My Marks         </a>
      }
      else if (role == "Teacher")
      {
        <div class="sb-section">Teacher</div>
        <a class="sb-link @(action=="Index"?"active":"")"        href="/Teacher/Index">       <span class="ico">⊞</span> Dashboard    </a>
        <a class="sb-link @(action=="Grievances"?"active":"")"   href="/Teacher/Grievances">  <span class="ico">✉</span> Grievances    </a>
        <a class="sb-link @(action=="Marks"?"active":"")"        href="/Teacher/Marks">       <span class="ico">◈</span> Manage Marks  </a>
        <a class="sb-link @(action=="Revaluations"?"active":"")" href="/Teacher/Revaluations"><span class="ico">↺</span> Revaluations  </a>
      }
      else if (role == "Principal")
      {
        <div class="sb-section">Principal</div>
        <a class="sb-link @(action=="Index"?"active":"")"      href="/Principal/Index">     <span class="ico">⊞</span> Dashboard      </a>
        <a class="sb-link @(action=="Grievances"?"active":"")" href="/Principal/Grievances"><span class="ico">✉</span> All Grievances  </a>
        <a class="sb-link @(action=="Students"?"active":"")"   href="/Principal/Students">  <span class="ico">◉</span> Students        </a>
        <a class="sb-link @(action=="Marks"?"active":"")"      href="/Principal/Marks">     <span class="ico">◈</span> All Marks        </a>
      }
    </nav>
    <div class="sb-foot">
      <a class="sb-logout" href="/Account/Logout"><span>⎋</span> Sign Out</a>
    </div>
  </aside>
  <main class="main-content">
    @RenderBody()
  </main>
</div>
}
else
{
  @RenderBody()
}
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
